[user]
	name = Pavel
	email = 14926950+prichodko@users.noreply.github.com
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIGB+Q3CovMTbLRI7Vv2nkgHrZsKM3YeiI+hNFFDS935O
[core]
  pager = less -r
  editor = /usr/bin/vim
	excludesfile = /Users/pavel/.gitignore
[alias]
  a = add .
  b = branch
  bb = branch -vv
  c = commit
  ca = commit --amend --no-edit
  cam = commit -am
  co = checkout
  d = diff
  f = fetch
  s = status -s
	g = log --graph --decorate --oneline --date-order
  h = help
  ai = add --interactive
  ci = clean --interactive
  r = rebase
  ri = rebase -i
  p = push
  r = remote
  rr = remote -vv
  l = log --decorate --oneline -n20
  last = log -2 --stat --abbrev-commit --relative-date HEAD
  unstage = reset HEAD --
  staged = ls-files --stage --abbrev
  untrack = rm --cached
  oneline = log -10 --pretty=format:\"%h - %cn, %cr : %s\"
  graph = log --decorate --graph --abbrev-commit --relative-date --all
  list = config -l
	cm = commit -m
	sync = pull --autostash && push
	undo = reset HEAD~1
  # stage and commit all the changes
  c = !git add --all && git commit -m
  # stage and commit all the changes with WIP as a commit message
  wip = !git add --all && git commit -m 'WIP'
	prune = !git branch -vv | grep \": gone]\" | awk \"{print $1}\" | xargs git branch -d
	pf = push --force-with-lease
	wtc = "!git worktree list | awk '{path=$1; sha=$2; branch=\"\"; for(i=3;i<=NF;i++) branch=branch (i>3?\" \":\"\") $i; printf \"%-40s %s\\n\", branch, path}' | fzf --multi | awk '{print $NF}' | xargs -I {} git worktree remove {}"
	wtx = "!f() {\n    selected_file=$(mktemp) || exit 1\n    trap 'rm -f \"$selected_file\"' EXIT INT TERM\n\n    git worktree list --porcelain |\n    awk '\n        BEGIN { RS=\"\"; FS=\"\\n\" }\n        {\n            path = \"\"\n            branch = \"(detached HEAD)\"\n\n            for (i = 1; i <= NF; i++) {\n                if ($i ~ /^worktree /) {\n                    path = substr($i, 10)\n                } else if ($i ~ /^branch /) {\n                    branch = substr($i, 8)\n                    sub(/^refs\\/heads\\//, \"\", branch)\n                } else if ($i == \"bare\") {\n                    branch = \"(bare)\"\n                } else if ($i == \"detached\") {\n                    branch = \"(detached HEAD)\"\n                }\n            }\n\n            printf \"%-35s\\t%s\\t%s\\n\", branch, branch, path\n        }\n    ' |\n    fzf --multi --delimiter=\"\t\" --with-nth=1,3 > \"$selected_file\"\n\n    [ ! -s \"$selected_file\" ] && exit 0\n\n    total=$(wc -l < \"$selected_file\" | tr -d ' ')\n    index=0\n    deleted=0\n    skipped=0\n    skipped_items=\"\"\n\n    while IFS=\"\t\" read -r _ branch path; do\n        index=$((index + 1))\n\n        printf \"[%s/%s] %s\\n\" \"$index\" \"$total\" \"$branch\"\n        printf \"    %s\\n\" \"$path\"\n\n        err=$(git worktree remove \"$path\" 2>&1)\n        if [ $? -eq 0 ]; then\n            deleted=$((deleted + 1))\n            printf \"    ✓ deleted\\n\\n\"\n        else\n            skipped=$((skipped + 1))\n\n            case \"$err\" in\n                *\"contains modified or untracked files\"*)\n                    printf \"    ✗ skipped: modified or untracked files\\n\\n\"\n                    ;;\n                *)\n                    printf \"    ✗ failed\\n\"\n                    printf \"      %s\\n\\n\" \"$err\"\n                    ;;\n            esac\n\n            skipped_items=\"${skipped_items}- ${branch}\\n  ${path}\\n\"\n        fi\n    done < \"$selected_file\"\n\n    printf \"Summary: %s deleted, %s skipped\\n\" \"$deleted\" \"$skipped\"\n\n    if [ \"$skipped\" -gt 0 ]; then\n        printf \"Skipped:\\n\"\n        printf \"%b\" \"$skipped_items\"\n    fi\n}; f"
[merge]
	# ff = only
	tool = vscode
[credential]
	helper = osxkeychain
[diff]
  tool = vscode
[difftool "vscode"]
  cmd = code --wait --diff $LOCAL $REMOTE
[mergetool "vscode"]
  cmd = code --wait --diff $LOCAL $REMOTE
[color]
	diff = auto
[pull]
	# ff = only
	# rebase = true
[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
[init]
	defaultBranch = main
[commit]
	gpgSign = true
	sign = true
[rebase]
	autoStash = true
[push]
	autoSetupRemote = true
[rerere]
	enabled = true
[gpg]
	format = ssh
[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
