// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        }
      },
      "enable_lsp_tasks": true
    }
  },
  "edit_predictions": {
    "provider": "zed",
  },
  "agent_buffer_font_size": 14.0,
  "agent_ui_font_size": 15.0,
  "ui_font_family": ".ZedSans",
  "buffer_font_family": ".ZedMono",
  "ui_font_size": 15.0,
  "buffer_font_weight": 400.0,
  "buffer_line_height": "standard",
  "buffer_font_size": 12.0,
  "git": {
    "inline_blame": {
      "enabled": false,
      "delay_ms": 100,
    },
  },
  "when_closing_with_no_tabs": "platform_default",
  "use_system_window_tabs": true,
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "favorite_models": [],
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "gpt-4.1",
    },
    "model_parameters": [],
  },
  "terminal": {
    "font_size": 12.0,
    "dock": "right",
    "cursor_shape": "bar",
  },
  "base_keymap": "Cursor",
  "toolbar": {
    "quick_actions": false,
    "breadcrumbs": false,
  },
  "git_panel": {
    "collapse_untracked_diff": false,
    "sort_by_path": true,
    "dock": "left",
    "tree_view": true,
  },
  "project_panel": {
    "dock": "left",
    "hide_root": true,
  },
  "ssh_connections": [
    {
      "host": "my-os.exe.xyz",
      "args": [],
      "projects": [
        {
          "paths": ["/home/exedev"],
        },
      ],
    },
  ],
  "theme": "GitHub Dark Tritanopia",
  "autosave": "on_window_change",
  "format_on_save": "on",
  "agent_servers": {
    "OpenCode": {
      "type": "custom",
      "command": "opencode",
      "args": ["acp"],
    },
  },
  "formatter": [
    {
      "language_server": {
        "name": "oxfmt",
      },
    },
  ],
  "languages": {
    "CSS": {
      "language_servers": [
        "tailwindcss-intellisense-css",
        "!vscode-css-language-server",
      ],
    },
  },
}
